# Database (Local PostgreSQL via Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adyatara?schema=public"

# Direct URL (Required for Supabase connection pooling; same as DATABASE_URL for local dev)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/adyatara?schema=public"

# NextAuth
NEXTAUTH_SECRET="development-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="development-secret-change-in-production"

# OAuth Providers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Public
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenRouter AI Chatbot
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-2.0-flash-lite-001"