generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String?         @unique
  emailVerified   DateTime?
  password        String?
  image           String?
  bio             String?
  avatarUrl       String?
  role            Role            @default(USER)
  level           Int             @default(1)
  totalScore      Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  accounts        Account[]
  gameSessions    GameSession[]
  sessions        Session[]
  userKnowledges  UserKnowledge[]
  userCollectibles UserCollectible[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, token])
}

model Story {
  id                     String          @id @default(cuid())
  title                  String
  region                 String
  description            String
  difficulty             String
  levelReq               Int             @default(1)
  coverImage             String?
  backgroundMusicDefault String?
  themeColor             String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  sessions               GameSession[]
  knowledges             Knowledge[]
  nodes                  Node[]
  collectibles           Collectible[]
}

model Character {
  id        String   @id @default(cuid())
  name      String
  avatar    String?
  region    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  nodes     Node[]
}

model Node {
  id               String     @id @default(cuid())
  storyId          String
  content          String
  type             String
  speakerId        String?
  backgroundImage  String?
  backgroundMusic  String?
  soundEffect      String?
  expression       String?
  position         String?    @default("center")
  isAutoPlay       Boolean    @default(false)
  delayMs          Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  choices          Choice[]   @relation("NodeChoices")
  currentCharacter Character? @relation(fields: [speakerId], references: [id])
  story            Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
}

model Choice {
  id            String       @id @default(cuid())
  nodeId        String
  text          String
  nextNodeId    String?
  scoreDelta    Int          @default(0)
  knowledgeId   String?
  collectibleId String?
  soundEffect   String?
  isImportant   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  knowledge     Knowledge?   @relation(fields: [knowledgeId], references: [id])
  collectible   Collectible? @relation(fields: [collectibleId], references: [id])
  node          Node         @relation("NodeChoices", fields: [nodeId], references: [id], onDelete: Cascade)
}

model GameSession {
  id            String    @id @default(cuid())
  userId        String
  storyId       String
  currentNodeId String
  score         Int       @default(0)
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  story         Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Knowledge {
  id        String          @id @default(cuid())
  title     String
  content   String
  category  String
  storyId   String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  choices   Choice[]
  story     Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  users     UserKnowledge[]
}

model UserKnowledge {
  id          String    @id @default(cuid())
  userId      String
  knowledgeId String
  unlockedAt  DateTime  @default(now())
  knowledge   Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, knowledgeId])
}

enum Role {
  USER
  ADMIN
}

model Collectible {
  id          String            @id @default(cuid())
  name        String
  description String?
  image       String
  rarity      String            @default("common")
  category    String?
  storyId     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  story       Story             @relation(fields: [storyId], references: [id], onDelete: Cascade)
  choices     Choice[]
  users       UserCollectible[]
}

model UserCollectible {
  id            String      @id @default(cuid())
  userId        String
  collectibleId String
  unlockedAt    DateTime    @default(now())
  collectible   Collectible @relation(fields: [collectibleId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, collectibleId])
}
